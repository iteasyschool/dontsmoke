<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="0dp">

    <!-- Главная область — нажатие для смены слайда -->
    <LinearLayout
        android:id="@+id/widget_main_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/widget_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱"
            android:textSize="20dp" />

        <TextView
            android:id="@+id/widget_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:gravity="center"
            android:maxLines="1"
            android:text="0м"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="18sp"
            android:autoSizeMaxTextSize="26sp"
            android:textColor="#FFFFFF"
            android:textSize="26dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="center"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="12dp"
            android:autoSizeMaxTextSize="18dp"
            android:text="Время без курения"
            android:textColor="#CCFFFFFF"
            android:textSize="12dp" />

        <!-- Точки + кнопка фона — сразу под текстом -->
        <RelativeLayout
            android:id="@+id/widget_bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/widget_dots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="● ○ ○ ○"
                android:textColor="#88FFFFFF"
                android:textSize="6dp" />

            <TextView
                android:id="@+id/widget_bg_btn"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="#33FFFFFF"
                android:gravity="center"
                android:text="◑"
                android:textColor="#CCFFFFFF"
                android:textSize="13dp" />

        </RelativeLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_slide_tap_zones"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/widget_prev_slide_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <FrameLayout
            android:id="@+id/widget_next_slide_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

    </LinearLayout>

</RelativeLayout>
